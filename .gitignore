# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example committed but ignore the rest
.env
.env.local
.env.*.local
.env.production
.env.development

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*

# logs
*.log
dev.log
server.log

# local dev artifacts
/dev-daemon.py
/start-dev.sh
/worklog.md
/tool-results/
/upload/
/download/
/examples/
/mini-services/
/Caddyfile
/.zscripts/

# local SQLite database (only used in dev with DATA_BACKEND=local)
/db/*.db
/db/*.db-journal

# editor / AI assistant configs
.claude
.z-ai-config
prompt
testbun.lock
