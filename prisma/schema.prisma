// Velixa Capital — database schema (local dev/preview backend via SQLite).
// This mirrors the Supabase schema (see /supabase/migrations) and adds the
// CRM, call-sheet, partner-file and audit tables. The data layer in
// src/lib/data abstracts reads/writes so the app runs on either SQLite
// (DATA_BACKEND=local, default) or Supabase (DATA_BACKEND=supabase).
//
// Sensitive PII (name, mobile, email, pan) is stored AES-256-GCM encrypted
// at the application layer (see src/lib/crypto.ts) regardless of backend.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  displayName  String?
  role         String   @default("user") // admin | employee | partner | user
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee          Employee?
  partnerProfile    PartnerProfile?
  affiliateLinks    AffiliateLink[]  @relation("AffiliateOwner")
  blogs             Blog[]           @relation("BlogAuthor")
  uploadedSheets    CallSheet[]      @relation("SheetUploader")
  auditLogs         AuditLog[]
}

model Lead {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  name            String   // encrypted
  mobile          String   // encrypted
  email           String   // encrypted
  pan             String?  // encrypted
  employmentType  String?
  monthlyIncome   Float?
  businessDetails String?
  service         String?
  loanAmount      Float?
  city            String?
  message         String?
  sourcePage      String?
  status          String   @default("new") // new|contacted|qualified|converted|lost
  notes           String?
  affiliateId     String?
  affiliateSlug   String?
  assignmentId    String?  @unique // linked CRM assignment if routed to an employee
  assignment      CallAssignment? @relation(fields: [assignmentId], references: [id])

  @@index([createdAt])
  @@index([status])
}

model Blog {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String    @default("")
  content     String    @default("")
  coverImage  String?
  authorId    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User?     @relation("BlogAuthor", fields: [authorId], references: [id])

  @@index([published])
  @@index([publishedAt])
}

model CreditCard {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  bank         String
  category     String
  imageUrl     String?
  annualFee    Float     @default(0)
  joiningFee   Float     @default(0)
  features     String    @default("[]") // JSON string[]
  benefits     String    @default("")
  affiliateUrl String?
  published    Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published])
}

model Career {
  id              String   @id @default(cuid())
  title           String
  department      String?
  location        String   @default("Remote / India")
  employmentType  String   @default("Full-time")
  shortDescription String
  description     String
  requirements    String   @default("[]") // JSON string[]
  salaryRange     String?
  applyEmail      String   @default("careers@velixacapital.in")
  published       Boolean  @default(true)
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published])
}

model AffiliateLink {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  targetUrl   String
  description String?
  clicks      Int      @default(0)
  leadCount   Int      @default(0)
  ownerId     String?
  createdBy   String?
  createdAt   DateTime @default(now())
  owner       User?    @relation("AffiliateOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([slug])
}

model PartnerApplication {
  id                   String   @id @default(cuid())
  fullName             String
  mobile               String   // encrypted
  email                String   // encrypted
  pan                  String?  // encrypted
  city                 String
  currentProfession    String?
  businessType         String?
  experienceYears      Int      @default(0)
  expectedMonthlyLeads Int      @default(0)
  message              String?
  sourcePage           String?
  status               String   @default("new") // new|approved|rejected
  createdAt            DateTime @default(now())
}

// ===== CRM: employees, call sheets, assignments, outcomes =====

model Employee {
  id           String   @id @default(cuid())
  userId       String   @unique
  fullName     String   // encrypted
  mobile       String   // encrypted
  email        String   // encrypted
  employeeCode String?
  designation  String?
  targetCalls  Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  assignments  CallAssignment[]
  outcomes     CallOutcome[]
  followUps    FollowUp[]

  @@index([isActive])
}

model CallSheet {
  id           String   @id @default(cuid())
  name         String
  uploadedById String?
  fileName     String?
  totalRecords Int      @default(0)
  createdAt    DateTime @default(now())
  uploader     User?    @relation("SheetUploader", fields: [uploadedById], references: [id])
  assignments  CallAssignment[]

  @@index([createdAt])
}

model CallAssignment {
  id             String   @id @default(cuid())
  callSheetId    String?
  employeeId     String?  // null = available in universal pool
  customerName   String   // encrypted
  customerMobile String   // encrypted
  customerEmail  String?  // encrypted
  city           String?
  service        String?
  loanAmount     Float?
  employmentType String?
  monthlyIncome  Float?
  notes          String?
  status         String   @default("available") // available|in_progress|success|rejected|not_connected|reschedule|callback|converted|dnd
  priority       Int      @default(0)
  assignedAt     DateTime @default(now())
  claimedAt      DateTime?
  dueDate        DateTime?
  callSheet      CallSheet? @relation(fields: [callSheetId], references: [id])
  employee       Employee?  @relation(fields: [employeeId], references: [id])
  outcomes       CallOutcome[]
  followUps      FollowUp[]
  lead           Lead?

  @@index([employeeId])
  @@index([status])
  @@index([callSheetId])
}

model CallOutcome {
  id              String   @id @default(cuid())
  assignmentId    String
  employeeId      String?
  outcome         String   // connected|no_answer|wrong_number|busy|voicemail
  disposition     String   // success|rejected|not_connected|reschedule|callback|converted|dnd
  callDurationSec Int      @default(0)
  notes           String?
  callbackAt      DateTime?
  convertedAmount Float?
  createdAt       DateTime @default(now())
  assignment      CallAssignment @relation(fields: [assignmentId], references: [id])
  employee        Employee?      @relation(fields: [employeeId], references: [id])

  @@index([assignmentId])
  @@index([employeeId])
}

model FollowUp {
  id           String   @id @default(cuid())
  assignmentId String
  employeeId   String?
  scheduledAt  DateTime
  note         String?
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  assignment   CallAssignment @relation(fields: [assignmentId], references: [id])
  employee     Employee?      @relation(fields: [employeeId], references: [id])

  @@index([assignmentId])
  @@index([employeeId])
  @@index([scheduledAt])
}

// ===== Partner Portal: file submissions =====

model PartnerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  partnerCode   String?
  companyName   String?
  mobile        String?  // encrypted
  city          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
  fileSubmissions PartnerFile[]
}

model PartnerFile {
  id             String   @id @default(cuid())
  partnerId      String?
  customerName   String   // encrypted
  customerMobile String   // encrypted
  customerEmail  String?  // encrypted
  city           String?
  service        String?
  loanAmount     Float?
  employmentType String?
  fileName       String?
  fileUrl        String?  // encrypted (storage path / key)
  notes          String?
  status         String   @default("new") // new|in_review|submitted_to_bank|sanctioned|rejected
  adminNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  partner        PartnerProfile? @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorRole String?
  action    String
  entity    String?
  entityId  String?
  meta      String?  // JSON
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([entity])
}

model ChatMessage {
  id         String   @id @default(cuid())
  userId     String?
  userName   String
  userRole   String?
  channel    String   @default("general")
  content    String
  createdAt  DateTime @default(now())

  @@index([channel])
  @@index([createdAt])
}
